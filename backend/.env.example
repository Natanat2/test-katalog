# Application
APP_NAME=Interactive Catalog API
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

# Frontend origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=catalog_db
DB_USER=catalog_user
DB_PASSWORD=catalog_password

# Optional: if set, overrides DB_* values above
# DATABASE_URL=postgresql+psycopg://catalog_user:catalog_password@localhost:5432/catalog_db
# For Docker backend service use:
# DATABASE_URL=postgresql+psycopg://catalog_user:catalog_password@postgres:5432/catalog_db
